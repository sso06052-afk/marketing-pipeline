# ─────────────────────────────────────────────
#  마케팅 파이프라인 환경변수 (실제 코드 기준)
#  실제 값은 secrets.local.txt 에 넣고 setup-deploy.ps1 실행
# ─────────────────────────────────────────────

# Supabase (DB) — Settings → API
SUPABASE_URL=
SUPABASE_KEY=            # service_role 권장

# 인스타 탐색 (serper.dev)
SERPER_API_KEY=

# 인스타 계정 판별 (aistudio.google.com)
GEMINI_API_KEY=

# 멜론 크롤링 (선택 — 없으면 빈칸)
MELON_COOKIE=

# 서버 인증 — 대시보드와 동일 값이어야 함 (setup 스크립트가 자동 생성)
API_SECRET=

# CORS 허용 출처 (배포된 Vercel 주소)
ALLOWED_ORIGINS=https://dashboard-jade-ten-65.vercel.app
